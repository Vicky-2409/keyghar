# Public site URL (sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://keyghar.online

# Support email shown on Contact / legal pages
NEXT_PUBLIC_SUPPORT_EMAIL=support@keyghar.online

# Google Search Console — HTML tag verification value (optional until you apply)
# Get from: https://search.google.com/search-console → Add property → HTML tag
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google AdSense — add AFTER approval (leave empty until then)
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_SEARCH=
NEXT_PUBLIC_ADSENSE_SLOT_PROPERTY=
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_BOTTOM=
NEXT_PUBLIC_ADSENSE_SLOT_DEFAULT=

# Razorpay — contact owner paywall (₹49/month subscription)
# Create a monthly plan in https://dashboard.razorpay.com/app/plans
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_key
RAZORPAY_PLAN_ID=plan_xxxxxxxx
